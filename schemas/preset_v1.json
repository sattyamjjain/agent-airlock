{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "agent-airlock declarative preset (v1)",
  "type": "object",
  "required": ["schema_version", "preset_id", "presets", "primary_source", "disclosed_at"],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "preset_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "description": {"type": "string"},
    "primary_source": {"type": "string", "format": "uri"},
    "disclosed_at": {"type": "string", "pattern": "^\\d{4}(?:-\\d{2}(?:-\\d{2})?)?$"},
    "presets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "factory", "primary_source"],
        "properties": {
          "id": {"type": "string"},
          "factory": {"type": "string"},
          "cve_id": {"type": "string", "pattern": "^CVE-\\d{4}-\\d+$"},
          "primary_source": {"type": "string", "format": "uri"},
          "disclosed_at": {"type": "string"},
          "enabled": {"type": "boolean"},
          "allowlist_fallback": {"type": "boolean"}
        }
      }
    }
  }
}
